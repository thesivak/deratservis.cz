---
const { copy, references } = Astro.props as { copy: any; references: any[] };
const sorted = [...references].sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section id="reference" class="relative overflow-hidden py-16 md:py-24">
  <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-1/2 bg-gradient-to-b from-orange-100/60 to-white"></div>
  <div class="relative z-10 mx-auto max-w-7xl px-8">
    <div class="mb-12 text-center">
      <h2 class="text-4xl font-bold text-gray-900 md:text-5xl">{copy.heading}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg font-medium text-gray-700 md:text-xl">{copy.subtitle}</p>
    </div>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {sorted.map((reference) => (
        <article class="flex h-full flex-col rounded-2xl border border-orange-100 bg-white p-6 shadow-sm md:p-8">
          <svg class="mb-4 h-10 w-10 text-orange-200" fill="currentColor" viewBox="0 0 32 32"><path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14H7c0-1.7 1.3-3 3-3V8zm18 0c-3.3 0-6 2.7-6 6v10h10V14h-7c0-1.7 1.3-3 3-3V8z"></path></svg>
          <div class="mb-4 flex items-center space-x-1" aria-label="5 z 5 hvězdiček">
            {Array.from({ length: 5 }).map(() => <svg class="h-5 w-5 fill-yellow-400 text-yellow-400" viewBox="0 0 20 20"><polygon points="10,1 12.59,7.36 19.51,7.36 13.95,11.63 16.54,17.99 10,13.72 3.46,17.99 6.05,11.63 0.49,7.36 7.41,7.36"></polygon></svg>)}
          </div>
          <p class="mb-6 flex-1 text-lg italic text-gray-700">"{reference.data.testimonial}"</p>
          <div class="mt-auto flex items-center border-t border-orange-100 pt-4">
            <div class="mr-4 flex h-12 w-12 items-center justify-center rounded-full border-2 border-orange-100 bg-orange-50 text-orange-700">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm-4 7a7 7 0 0 0-7 7h14a7 7 0 0 0-7-7Z"></path></svg>
            </div>
            <div>
              <div class="font-bold text-gray-900">{reference.data.clientName}</div>
              {reference.data.clientRole && <div class="text-sm text-orange-700">{reference.data.clientRole}</div>}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
