---
import Button from "./Button.astro";
import Icon from "./Icon.astro";
const { contact } = Astro.props as { contact: any };
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<section id="kontakt" class="bg-gradient-to-b from-white to-gray-50 py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-8">
    <div class="mb-16 text-center">
      <h2 class="text-4xl font-bold text-gray-900 md:text-5xl">{contact.heading}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg font-medium text-gray-700 md:text-xl">{contact.description}</p>
    </div>
    <div class="grid gap-12 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <div class="h-full rounded-xl border border-orange-100 bg-white p-8 shadow-sm">
          <h3 class="mb-6 text-2xl font-bold text-gray-900">Kontaktní informace</h3>
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="mr-4 flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-orange-50 text-orange-700"><Icon name="phone" class="h-5 w-5" /></div>
              <div>
                <h4 class="text-lg font-semibold text-gray-900">Telefon</h4>
                <a class="text-gray-600 hover:text-orange-700" href={`tel:${contact.phone.replaceAll(" ", "")}`}>{contact.phone}</a>
              </div>
            </div>
            <div class="flex items-start">
              <div class="mr-4 flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-orange-50 text-orange-700"><Icon name="mail" class="h-5 w-5" /></div>
              <div>
                <h4 class="text-lg font-semibold text-gray-900">Email</h4>
                <a class="text-gray-600 hover:text-orange-700" href={`mailto:${contact.email}`}>{contact.email}</a>
              </div>
            </div>
            <div class="flex items-start">
              <div class="mr-4 flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-orange-50 text-orange-700"><Icon name="map" class="h-5 w-5" /></div>
              <div>
                <h4 class="text-lg font-semibold text-gray-900">Firemní údaje</h4>
                <address class="not-italic text-gray-600"><span set:html={contact.addressHtml} /><br />IČ: {contact.ic}</address>
              </div>
            </div>
          </div>
          <div class="mt-8 border-t border-gray-100 pt-8">
            <h4 class="mb-3 text-lg font-semibold text-gray-900">Oblast působení</h4>
            <p class="text-gray-600">{contact.serviceArea}</p>
          </div>
        </div>
      </div>
      <div class="lg:col-span-3">
        <div class="rounded-xl border border-orange-100 bg-white p-8 shadow-sm">
          <h3 class="mb-6 text-2xl font-bold text-gray-900">Napište nám</h3>
          <form id="contactForm" class="space-y-6" action="/api/contact" method="POST">
            <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
            <div id="formAlert" class="mb-6 hidden rounded-md border p-4">
              <p id="alertMessage" class="text-sm font-medium"></p>
            </div>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="full_name" class="mb-1 block text-sm font-medium text-gray-700">Jméno a příjmení *</label>
                <input type="text" id="full_name" name="full_name" required class="w-full rounded-md border border-gray-300 px-4 py-3 transition-all focus:border-transparent focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="Zadejte vaše jméno" />
              </div>
              <div>
                <label for="email" class="mb-1 block text-sm font-medium text-gray-700">Email *</label>
                <input type="email" id="email" name="email" required class="w-full rounded-md border border-gray-300 px-4 py-3 transition-all focus:border-transparent focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="vas@email.cz" />
              </div>
            </div>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="phone" class="mb-1 block text-sm font-medium text-gray-700">Telefon *</label>
                <input type="tel" id="phone" name="phone" required class="w-full rounded-md border border-gray-300 px-4 py-3 transition-all focus:border-transparent focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="+420 XXX XXX XXX" />
              </div>
              <div>
                <label for="service_type" class="mb-1 block text-sm font-medium text-gray-700">Typ služby *</label>
                <select id="service_type" name="service_type" required class="w-full rounded-md border border-gray-300 px-4 py-3 transition-all focus:border-transparent focus:outline-none focus:ring-2 focus:ring-orange-500">
                  <option value="">Vyberte typ služby</option>
                  <option value="deratizace">Deratizace</option>
                  <option value="dezinfekce">Dezinfekce</option>
                  <option value="dezinsekce">Dezinsekce</option>
                  <option value="ochrana dreva">Ochrana dřeva</option>
                  <option value="poradenstvi">Poradenství</option>
                  <option value="jiny">Jiný</option>
                </select>
              </div>
            </div>
            <div>
              <label for="notes" class="mb-1 block text-sm font-medium text-gray-700">Zpráva *</label>
              <textarea id="notes" name="notes" required rows="5" class="w-full rounded-md border border-gray-300 px-4 py-3 transition-all focus:border-transparent focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="Popište váš požadavek..."></textarea>
            </div>
            {turnstileSiteKey && (
              <div
                class="cf-turnstile"
                data-sitekey={turnstileSiteKey}
                data-theme="light"
                data-size="normal"
              />
            )}
            <Button type="submit" fullWidth={true} icon="send">Odeslat zprávu</Button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

{turnstileSiteKey && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("contactForm") as HTMLFormElement | null;
    const alert = document.getElementById("formAlert");
    const message = document.getElementById("alertMessage");
    if (!form || !alert || !message) return;
    const resetTurnstile = () => {
      const turnstile = (window as any).turnstile;
      if (turnstile?.reset) turnstile.reset();
    };
    const showMessage = (text: string, ok = false) => {
      alert.className = `mb-6 rounded-md border p-4 ${ok ? "border-green-400 bg-green-50" : "border-orange-400 bg-orange-50"}`;
      message.className = `text-sm font-medium ${ok ? "text-green-800" : "text-orange-800"}`;
      message.textContent = text;
      alert.scrollIntoView({ behavior: "smooth", block: "center" });
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const button = form.querySelector("button[type='submit']") as HTMLButtonElement | null;
      if (!button) return;
      const originalButtonHtml = button.innerHTML;
      const hasTurnstile = Boolean(form.querySelector(".cf-turnstile"));
      const turnstileToken = String(new FormData(form).get("cf-turnstile-response") || "");
      if (hasTurnstile && !turnstileToken) {
        showMessage("Ověření formuláře ještě není dokončeno. Zkuste to prosím znovu za chvíli.");
        return;
      }

      button.disabled = true;
      button.textContent = "Odesílám...";

      try {
        const response = await fetch(form.action, { method: "POST", body: new FormData(form), headers: { "Accept": "application/json" } });
        const data = await response.json();
        showMessage(data.message || (response.ok ? "Zpráva byla odeslána." : "Odeslání se nezdařilo."), response.ok);
        if (response.ok) form.reset();
      } catch {
        showMessage("Nastala chyba připojení při odesílání formuláře. Zkuste to prosím znovu.");
      } finally {
        resetTurnstile();
        button.disabled = false;
        button.innerHTML = originalButtonHtml;
      }
    });
  });
</script>
