---
import Button from "./Button.astro";
import BlogCard from "./BlogCard.astro";
const { copy, posts } = Astro.props as { copy: any; posts: any[] };
const latest = [...posts].sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()).slice(0, 3);
---

{latest.length > 0 && (
  <section id="blog" class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-8">
      <div class="mb-16 text-center">
        <h2 class="text-4xl font-bold text-gray-900 md:text-5xl">{copy.heading}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg font-medium text-gray-700 md:text-xl">{copy.subtitle}</p>
      </div>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {latest.map((post) => <BlogCard post={post} />)}
      </div>
      <div class="mt-12 text-center">
        <Button href="/blog/">Všechny články</Button>
      </div>
    </div>
  </section>
)}
