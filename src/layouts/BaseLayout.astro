---
import "../styles.css";
import Seo from "@/components/Seo.astro";
import JsonLd from "@/components/JsonLd.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";

const {
  title,
  description,
  image,
  type,
  publishedAt,
  updatedAt,
  isBlogPage = false,
  hasBlog = true,
  jsonLd = []
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ldItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <Seo title={title} description={description} canonical={canonical} image={image} type={type} publishedAt={publishedAt} updatedAt={updatedAt} />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    {ldItems.map((item) => item && <JsonLd data={item} />)}
  </head>
  <body class={`antialiased ${isBlogPage ? "blog-page" : ""}`}>
    <Navbar isBlogPage={isBlogPage} hasBlog={hasBlog} />
    <main>
      <slot />
    </main>
    <Footer hasBlog={hasBlog} />
  </body>
</html>
