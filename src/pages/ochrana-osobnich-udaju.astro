---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const blogPosts = await getCollection("blog");
const hasBlog = blogPosts.length > 0;
---

<BaseLayout title="Zásady ochrany osobních údajů | DERATservis" description="Informace o zpracování osobních údajů při odeslání poptávkového formuláře DERATservis." hasBlog={hasBlog}>
  <main class="bg-white pb-16 pt-32">
    <div class="prose prose-lg mx-auto max-w-4xl px-6">
      <h1>Zásady ochrany osobních údajů</h1>
      <p>Osobní údaje z poptávkového formuláře používáme pouze pro vyřízení vašeho požadavku a následnou komunikaci.</p>
      <p>Zpracovávané údaje zahrnují jméno, e-mail, telefon, typ služby a text zprávy. Údaje nejsou používány pro hromadný marketing ani předávány třetím stranám mimo technické poskytovatele potřebné pro doručení zprávy.</p>
      <p>Pro dotazy k ochraně osobních údajů nás kontaktujte na <a href="mailto:info@deratservis.cz">info@deratservis.cz</a>.</p>
    </div>
  </main>
</BaseLayout>
