---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCard from "@/components/BlogCard.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.publishedAt <= new Date())
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const hasBlog = posts.length > 0;
---

<BaseLayout
  title="Blog - DERATservis"
  description="Přečtěte si nejnovější články o deratizaci, dezinsekci, dezinfekci a ochraně dřeva od odborníků DERATservis."
  isBlogPage={true}
  hasBlog={hasBlog}
>
  <div class="bg-white pb-16 pt-32">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <h1 class="mb-4 text-4xl font-bold text-gray-900">Blog DERATservis</h1>
        <p class="mx-auto max-w-3xl text-lg text-gray-600">Přečtěte si nejnovější články a rady od našich odborníků na deratizaci, dezinsekci a ochranu dřeva.</p>
      </div>
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => <BlogCard post={post} />)}
        </div>
      ) : (
        <div class="py-12 text-center">
          <p class="text-xl text-gray-600">V současné době nemáme žádné publikované články.</p>
          <p class="mt-2 text-lg text-gray-500">Navštivte nás brzy znovu pro nový obsah.</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
